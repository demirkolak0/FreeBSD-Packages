# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
	output_format = "i3bar"
	colors = true
	# color_good = "#BBBBBB"
	# color_bad = "#CC1616"
	# color_degraded = "#55858E"
}

#order += "ipv6"
order += "cpu_usage"
order += "memory"
order += "disk /"
#order += "run_watch DHCP"
#order += "run_watch VPN"
order += "ethernet wifibox0"
# order += "wireless _first_"
order += "ethernet ue0"
# order += "ethernet _first_"
order += "battery all"
#order += "load"
order += "volume master"
order += "tztime local2"
order += "tztime local"

volume master {
	format = " ♪: %volume  " 
          device = "default"
          mixer = "Master"
          mixer_idx = 0
 format = "volume: %volume "




}
wireless _first_ {
        format_up = "W: (%quality at %essid)"
        format_down = "W: down"
}

ethernet _first_ {
        # if you use %speed, i3status requires root privileges
        format_up = "E: %ip (%speed)"
        format_down = "E: down"
}
ethernet wifibox0 {
	format_up = "wifibox: %ip (%speed)"
	format_down = "wifibox: down"
}
ethernet ue0 {
	format_up = "USB Ethernet: %ip (%speed)"
	format_down = "USB Ethernet: down"
}
battery all {
        format = "%status %percentage %remaining %emptytime"
	format_down = "No battery"
	path = "/sys/class/power_supply/BAT%d/uevent"
	low_threshold = 10
}

memory {
	format = "Memory: %used | %available"
	threshold_degraded = "10%"
	format_degraded = "Memory: %free"
}

run_watch DHCP {
        pidfile = "/var/run/dhclient*.pid"
}

run_watch VPN {
        pidfile = "/var/run/vpnc/pid"
}

tztime local {
        format = "%H:%M"
}

tztime local2 {
        format = "%d-%m-20%y"
}

load {
        format = "%1min"
}

disk "/" {
        format = "/: %avail"
}

cpu_usage {
	format = "CPU: %usage"


}
